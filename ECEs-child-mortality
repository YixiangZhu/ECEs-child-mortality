library(foreign)
library(lubridate)
library(lme4)
library(ggplot2)
library(dlnm)
library(splines)
library(survival)

#===========================================================================================================================
load("C:/Users/yxzhu/Desktop/DHS_data_analysis/EWE_children_mortality/model_analysis/frame_u5mr_temp_month.rda")
load("C:/Users/yxzhu/Desktop/DHS_data_analysis/EWE_children_mortality/model_analysis/frame_u5mr_precip_month.rda")
load("C:/Users/yxzhu/Desktop/DHS_data_analysis/EWE_children_mortality/model_analysis/frame_u5mr_flood_total.rda")

frame_u5mr_flood <- data.frame(frame_u5mr_temp_month, frame_u5mr_precip_month, frame_u5mr_flood_total)
#===========================================================================================================================
data <- frame_u5mr_flood

met_extr_flood <- subset(data,select=c(
    lag_1m_flood, lag_2m_flood,lag_3m_flood,lag_4m_flood,lag_5m_flood, lag_6m_flood,
    lag_7m_flood,lag_8m_flood,lag_9m_flood,lag_10m_flood, lag_11m_flood,lag_12m_flood,lag_1_12m_flood
    ))

#===========================================================================================================================
result_merge <- data.frame(matrix(NA, 13, 5))

colnames(result_merge) <- c("Lag", "P", "OR", "OR_low", "OR_high")

result_merge[,1] <- c("Lag 1", "Lag 2","Lag 3","Lag 4",  "Lag 5", "Lag 6", "Lag 7", "Lag 8",
 "Lag 9", "Lag 10", "Lag 11", "Lag 12", "Lag 1_12")

for(i in 1:13){

    cat(i)

model <- clogit(formula = u5mr ~ met_extr_flood[,i]
        + as.factor(death_year) 
        + as.factor(death_month)
        + maternal_age_death
        + ns(lag_0m_temp, 6)
        + ns(lag_0m_precip, 3)
        + CPI
        + GDP
        + as.factor(DHS_survey)
        + as.factor(bnum)
        + as.factor(sex)
        + strata(caseid)
        ,method = "breslow"
        ,data=data, na.action=na.omit)

coef<-data.frame(summary(model)$coefficients)
exp<-data.frame(exp(coef(model)))
conf<-data.frame(exp(confint(model)))
p<-round(coef[1,5],3)
OR<-round(exp[1,1],3)
OR_high<-round(conf[1,2],3)
OR_low<-round(conf[1,1],3)

result<-data.frame(P=p,coefficient=OR,low=OR_low,high=OR_high)

result_merge[i, c(2:5)] <- result

}

