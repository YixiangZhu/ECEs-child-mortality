#===========================================================================================================================
library(foreign)
library(lubridate)
library(lme4)
library(ggplot2)
library(dlnm)
library(splines)
library(survival)

#===========================================================================================================================
load("C:/Users/yxzhu/Desktop/DHS_data_analysis/EWE_children_mortality/model_analysis/frame_u5mr_temp_month.rda")
load("C:/Users/yxzhu/Desktop/DHS_data_analysis/EWE_children_mortality/model_analysis/frame_u5mr_precip_month.rda")
load("C:/Users/yxzhu/Desktop/DHS_data_analysis/EWE_children_mortality/model_analysis/frame_u5mr_hw.rda")

frame_u5mr_hw <- data.frame(frame_u5mr_temp, frame_u5mr_precip, frame_u5mr_hw)
#===========================================================================================================================
data <- frame_u5mr_hw

met_hw_90_2 <- subset(data,select=c(
    lag_1m_hw_90_2,lag_2m_hw_90_2,lag_3m_hw_90_2,lag_4m_hw_90_2,lag_5m_hw_90_2,lag_6m_hw_90_2,
    lag_7m_hw_90_2,lag_8m_hw_90_2,lag_9m_hw_90_2,lag_10m_hw_90_2,lag_11m_hw_90_2,lag_12m_hw_90_2
    ))

met_hw_90_2 <- ifelse(met_hw_90_2 == 0, 0 ,1)

#===========================================================================================================================
arglag <-equalknots(c(1,12), fun="ns", df=3, intercept=FALSE) 

cbECE <- crossbasis(met_hw_90_2 ,lag=c(1,12),argvar=list(fun="lin"),arglag = list(fun="poly",degree=3))

model <- clogit(formula = u5mr ~ cbECE
        + as.factor(death_year) 
        + as.factor(death_month)
        + maternal_age_death
        + ns(lag_0m_temp, 6)
        + ns(lag_0m_precip, 3)
        + CPI
        + GDP
        + as.factor(DHS_survey)
        + as.factor(bnum)
        + as.factor(sex)
        + strata(caseid)
        ,method = "breslow"
        ,data=data, na.action=na.omit)

overall_pred_ECE_lag <- crosspred(cbECE,model,by= 1,cen = 0, cumul = TRUE)

plot(overall_pred_ECE_lag,"slices",var=1,main="Heatwave exposure",cumul = FALSE,col="black",
 xlab="Lag (month)", ylab="Odds ratio",
 cex.main=1.8,cex.lab=1.8, cex.axis=1.5,lwd=4, ylim=c(0.98,1.02),
     ci.arg=list(col = grey(0.7)))

overall_pred_ECE_ER_dlnm <- crosspred(cbECE,model,by= 1, cen= 0, cumul = TRUE)

result_hw_serise <- data.frame(with(overall_pred_ECE_ER_dlnm,cbind(cumRRfit[,12],cumRRlow[,12],cumRRhigh[,12])))

result_hw_serise$ECE <- rownames(result_hw_serise)

result_hw_value <- result_hw_serise[which(result_hw_serise$ECE == 1),]

